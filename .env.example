# Copy this file to .env.local and fill in your values.
#
# The Contentstack Digital Concierge "apiKey" is the AGENT ID — the same id
# that appears in the execute URL: /digital-concierge/agents/<apiKey>/execute
CONCIERGE_API_KEY=cs019f084cd4d97000af9910cba84d6b8e

# Region for the SDK: AZURE_EU or AWS_NA
CONCIERGE_REGION=AZURE_EU

# The x-user-id the agent expects (identifies the caller). Optional —
# the SDK auto-generates one if omitted.
CONCIERGE_USER_ID=csa9afb9a716dd1fcf
